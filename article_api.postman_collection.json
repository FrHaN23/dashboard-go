          "raw": "{\n    \"title\": \"Belajar Dasar Pemrograman Golang REST API Bawaan\",\n    \"content\": \"Ini adalah konten artikel tutorial Golang REST API yang dibuat sangat panjang agar dapat memenuhi syarat validasi minimal dua ratus karakter pada tugas backend sharing vision kali ini tanpa menggunakan framework tambahan apapun.\",\n    \"category\": \"Golang\",\n    \"status\": \"draft\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:{{port}}/article/",
          "protocol": "http",
          "host": ["localhost"],
          "path": ["article", ""],
          "variable": [
            {
              "key": "port",
              "value": "{{port}}"
            }
          ]
        },
        "description": "Endpoint untuk membuat artikel baru dengan data valid (Title >= 20 char, Content >= 200 char, Status 'publish')."
      },
      "response": []
    },
